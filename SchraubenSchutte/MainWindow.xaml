<Window x:Class="SchraubenSchuette.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SchraubenSchuette"
        Title="Schrauben Schütte GmbH" Height="630" Width="900">

    <Window.DataContext>
        <local:ProductViewModel />
    </Window.DataContext>

    <Grid Margin="10,10,10,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="331*"/>
            <ColumnDefinition Width="109*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Schrauben Schütte GmbH" FontSize="32" FontWeight="Bold" HorizontalAlignment="Left" Margin="247,10,0,10" />

        <Grid Grid.Row="1" Margin="0,10,0,0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBox Margin="0,0,0,10" Height="30" FontSize="14"
                         Text="{Binding Suchtext, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding GefilterteProdukte}" 
                         SelectedItem="{Binding SelectedProduct}"
                         DisplayMemberPath="Bezeichnung"
                         Height="439" Background="AliceBlue" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Background="#F7F7F7" Height="480">
                    <StackPanel>
                        <TextBlock Text="Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />
                        <Image Source="{Binding SelectedProduct.BildPfad}" Height="150" Margin="0,0,0,10" />
                        <TextBlock Text="Artikelnummer:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Artikelnummer}" />
                        <TextBlock Text="Bezeichnung:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Bezeichnung}" />
                        <TextBlock Text="Anzahl:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Anzahl}" />
                        <TextBlock Text="Material:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Material}" />
                        <TextBlock Text="Maße:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Maße}" />
                        <TextBlock Text="Einkaufspreis:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Einkaufspreis}" />
                        <TextBlock Text="Verkaufspreis:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Verkaufspreis}" />
                        <TextBlock Text="Lieferant:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProduct.Lieferant}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Grid.ColumnSpan="2">
            <Button Content="Artikel hinzufügen" Width="150" 
                    Click="BtnAddProduct_Click"/>
            <Button Content="Export nach Excel" Width="150" Margin="10,0,0,0"
        Click="BtnExportExcel_Click"/>
        </StackPanel>
    </Grid>
</Window>
